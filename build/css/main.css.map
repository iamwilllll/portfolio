/* Normal */
@font-face {
  font-family: "Montserrat";
  font-style: normal;
  font-weight: 100 900;
  src: url("/src/assets/fonts/Montserrat.ttf");
}
/* Italic */
@font-face {
  font-family: "Montserrat";
  font-style: italic;
  font-weight: 100 900;
  src: url("/src/assets/fonts/Montserrat-Italic.ttf");
}
#particles-js {
  position: absolute;
  inset: 0;
  z-index: -1;
}

.navigation {
  display: flex;
  justify-content: center;
  position: fixed;
  top: 5%;
  left: 50%;
  transform: translate(-50%, -50%);
  padding: 0.5rem;
  width: 90%;
  border-radius: 40px;
  animation-name: scroll;
  animation-range: 0 150px;
  animation-timeline: scroll();
  animation-fill-mode: forwards;
}
@media (min-width: 768px) {
  .navigation {
    width: 60%;
  }
}
@media (min-width: 1200px) {
  .navigation {
    width: 30%;
  }
}
.navigation__container {
  display: flex;
  margin: auto;
  gap: 4rem;
}
@media (min-width: 768px) {
  .navigation__container {
    gap: 5rem;
  }
}
.navigation__item {
  fill: #ffffff;
  stroke: #ffffff;
  width: 3rem;
  height: 3rem;
  transition-duration: 0.1s;
}
.navigation__item:hover {
  filter: drop-shadow(0px 0px 2px #ffffff);
  transform: scale(1.2);
  translate: 0px -7px;
}
@keyframes scroll {
  100% {
    backdrop-filter: blur(100px);
    background: rgba(255, 255, 255, 0.1019607843);
    border: solid 1px #ffffff;
    z-index: 10;
  }
}

.hero {
  color: #ffffff;
  padding: 0px 13%;
  margin-top: 20rem;
  height: 100vh;
  padding-top: 40%;
  margin-top: 0;
  color: #ffffff;
}
@media (min-width: 768px) {
  .hero {
    padding-top: 30%;
  }
}
@media (min-width: 1200px) {
  .hero {
    padding-top: 20%;
  }
}
.hero__title {
  margin-bottom: 1rem;
  font-size: 6rem;
}
.hero__subtitle {
  font-size: 2rem;
  font-weight: 300;
  padding: 1rem;
}
.hero__links__container {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}
@media (min-width: 768px) {
  .hero__links__container {
    width: 70%;
  }
}
@media (min-width: 1200px) {
  .hero__links__container {
    width: 30%;
  }
}
.hero__links__container a:hover {
  color: #ffffff;
  background-color: rgba(255, 255, 255, 0.6);
}
.hero__links {
  display: flex;
  align-items: center;
  text-align: center;
  gap: 0.5rem;
  font-size: 2rem;
  padding: 0.5rem;
  border: solid 1px #ffffff;
  border-radius: 20px;
  color: #ffffff;
  background-color: transparent;
  transition: 0.1s;
}
@media (min-width: 768px) {
  .hero__links {
    padding: 1rem;
  }
}
.hero__icons {
  fill: #ffffff;
  stroke: #ffffff;
  width: 40px;
  height: 40px;
}

.projects {
  color: #ffffff;
  padding: 0px 13%;
  margin-top: 20rem;
  text-align: center;
}
.projects__item:last-child {
  padding-top: 10rem;
}
@media (min-width: 768px) {
  .projects__item:last-child {
    padding-top: 0;
  }
}
.projects__item figure {
  margin-top: 1rem;
}
.projects__name {
  margin-bottom: 1.5rem;
}
.projects__container {
  display: grid;
  grid-template-columns: repeat(1, 1fr);
  gap: 5rem;
  padding: 0;
  margin: 0;
  list-style: none;
  margin: auto;
  text-align: center;
}
@media (min-width: 768px) {
  .projects__container {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 5rem;
  }
}
.projects__img {
  border-radius: 1rem;
  transition: 0.4s;
}
.projects__img:hover {
  transform: scale(1.05);
  z-index: 4;
}
.projects__name {
  font-size: 4rem;
  font-weight: 400;
}
.projects__icons {
  width: 4rem;
  height: 4rem;
}
.projects__description {
  color: #ffffff;
  font-size: 1.6rem;
}

.projects__links__container {
  margin: auto;
  width: 70%;
}
@media (min-width: 768px) {
  .projects__links__container {
    width: 80%;
  }
}
@media (min-width: 1200px) {
  .projects__links__container {
    width: 50%;
  }
}
.projects__links__container .projects__links {
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 2rem;
  border: solid 1px #ffffff;
  border-radius: 20px;
  margin: auto;
  padding: 0.5rem;
  gap: 1rem;
  background-color: transparent;
  transition: 0.1s;
  color: #ffffff;
}

.form {
  color: #ffffff;
  padding: 0px 13%;
  margin-top: 20rem;
  text-align: center;
  color: #ffffff;
}
.form__container {
  max-height: 530px;
  max-width: 895px;
  display: flex;
  flex-direction: column;
  text-align: center;
  align-items: center;
  width: 100%;
  padding: 5rem;
  margin: auto;
  gap: 30px;
  color: #ffffff;
  background-color: rgba(0, 0, 0, 0.5803921569);
  border-radius: 2rem;
}
.form__group {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  width: 100%;
}
@media (min-width: 768px) {
  .form__group {
    width: 80%;
  }
}
.form__label {
  font-size: 1.5rem;
  text-align: left;
}
.form__input, .form__textarea {
  background-color: transparent;
  color: #ffffff;
  border: none;
  border-bottom: solid 1px #3d3d3d;
  width: 100%;
  height: 30px;
  font-size: 15px;
  transition: 0.2s;
}
.form__input:focus, .form__input:hover, .form__textarea:focus, .form__textarea:hover {
  outline: none;
  border: none;
  background-color: transparent;
  border-bottom: solid 1px #ffffff;
}
.form__input:-webkit-autofill, .form__textarea:-webkit-autofill {
  background-color: transparent !important;
  color: #ffffff !important;
  border-bottom: solid 1px #ffffff !important;
  -webkit-text-fill-color: #ffffff;
  transition: background-color 0s ease-in-out 1000s;
}
.form__textarea {
  resize: none;
  height: 150px;
}
.form__button {
  border: solid 1px #ffffff;
  border-radius: 2rem;
  background-color: transparent;
  color: #ffffff;
  padding: 1.5rem;
  transition: 0.2s;
  font-size: 1.5rem;
  cursor: pointer;
}
@media (min-width: 768px) {
  .form__button {
    width: 80%;
    margin: auto;
  }
}
.form__button:hover {
  background-color: rgba(255, 255, 255, 0.6);
}
