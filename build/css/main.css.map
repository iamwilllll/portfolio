/* ----- Set the base font size on the HTML element for easier use of rem, em, and px. ----- */
html {
  font-size: 62.5%; /* 1rem = 10px (so, 1.6rem = 16px) */
  box-sizing: border-box;
  width: 100%;
  scroll-behavior: smooth;
  scroll-padding-top: 0rem;
  height: 100%;
}

/* ----- Inherit box-sizing in all elements and pseudo-elements ----- */
*,
*::before,
*::after {
  box-sizing: inherit;
}

/* ----- Set margins and padding in the body to avoid unwanted spaces ----- */
body {
  font-family: "Montserrat", sans-serif;
  font-optical-sizing: auto;
  font-style: normal;
  color: #000000;
  font-size: 2rem;
  margin: 0;
  padding: 0;
  background-color: #111111;
  height: 100%;
}

/** ----- Global styles ----- **/
p {
  color: #000000;
  line-height: 1.5;
}

.container {
  width: 95%;
  max-width: 120rem;
  margin: 0 auto;
}

a {
  text-decoration: none;
}

h1,
h2,
h3 {
  margin: 0 0 5rem 0;
  font-weight: 900;
}

h1 {
  font-size: 4rem;
}

h2 {
  font-size: 4.6rem;
}

h3 {
  font-size: 6rem;
  text-align: center;
}

img {
  max-width: 100%;
  width: 100%;
  height: auto;
  display: block;
}

main > section {
  padding: 10rem 0;
}